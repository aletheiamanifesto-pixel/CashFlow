// CashFlow — Schema Prisma
// Gestione depositi, utenti, KYC, payout e log AML

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  APPRAISER
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DepositStatus {
  PENDING     // Utente ha prenotato il deposito
  RECEIVED    // Oggetto ricevuto fisicamente
  APPRAISED   // Perizia completata, NFT mintato
  PAID        // Crypto inviata all'utente
  REJECTED    // Deposito rifiutato
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  walletAddress String?
  kycStatus     KycStatus   @default(PENDING)
  role          UserRole    @default(USER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deposits      Deposit[]
  kycDocuments  KycDocument[]
  payouts       Payout[]
  amlLogs       AmlLog[]

  @@index([email])
  @@index([walletAddress])
}

model KycDocument {
  id            String    @id @default(cuid())
  userId        String
  documentType  String    // doc_front, doc_back, selfie
  documentUrl   String    // path al file caricato
  sumsubId      String?   // ID applicazione Sumsub (se integrato)
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
}

model Deposit {
  id                String        @id @default(cuid())
  userId            String
  type              String        // gold, silver, watch, jewelry, gemstone, other
  description       String
  estimatedWeight   Float         // grammi (stima utente)
  estimatedValue    Float         // EUR — stima iniziale
  appraisedValue    Float?        // EUR — valore perizia ufficiale del perito
  status            DepositStatus @default(PENDING)
  photos            String[]      // array di path ai file caricati
  nftTokenId        String?       // ID del token NFT mintato su Polygon
  preferredCurrency String        @default("USDC") // USDC o USDT
  notes             String?       // note interne del perito
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  payout            Payout?

  @@index([userId])
  @@index([status])
}

model Payout {
  id            String        @id @default(cuid())
  depositId     String        @unique
  userId        String
  amount        Float         // importo in EUR/USD
  currency      String        // USDC o USDT
  txHash        String?       // hash transazione on-chain Polygon
  walletAddress String
  status        PayoutStatus  @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  deposit       Deposit       @relation(fields: [depositId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([txHash])
}

// Log obbligatorio per conformità AML (D.Lgs. 231/2007)
// Ogni operazione deve essere registrata. Le operazioni > €5.000 vengono flaggate.
// Le operazioni > €10.000 richiedono segnalazione all'UIF (Unità di Informazione Finanziaria).
model AmlLog {
  id            String    @id @default(cuid())
  userId        String?
  operationType String    // deposit_create, payout_execute, kyc_submit, etc.
  amount        Float?    // importo operazione in EUR
  flagged       Boolean   @default(false)
  flagReason    String?   // motivo segnalazione
  ipAddress     String?
  userAgent     String?
  metadata      Json?     // dati aggiuntivi operazione
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([flagged])
  @@index([createdAt])
}
